---
// Posts placeholder — en producción conectar con colección de Astro Content Collections
const posts = [
  { category: 'Exposiciones', title: 'Feria de primavera en la Peatonal', date: '10 Oct 2024', img: '/images/blog-1.jpg' },
  { category: 'Capacitaciones', title: 'Taller de marketing digital para emprendedoras', date: '5 Sep 2024', img: '/images/blog-2.jpg' },
  { category: 'Vinculaciones', title: 'Reunión con la Secretaría de Género', date: '22 Ago 2024', img: '/images/blog-3.jpg' },
  { category: 'Recursos', title: 'Nueva línea de microcréditos disponible', date: '15 Ago 2024', img: '/images/blog-4.jpg' },
  { category: 'Exposiciones', title: 'Activación solidaria en Plaza de Mayo', date: '1 Ago 2024', img: '/images/blog-5.jpg' },
  { category: 'Capacitaciones', title: 'Programa del emprendimiento a la empresa', date: '20 Jul 2024', img: '/images/blog-6.jpg' },
];

const categories = ['Todos', 'Exposiciones', 'Capacitaciones', 'Vinculaciones', 'Recursos'];
---

<section id="novedades" class="novedades">
  <div class="container">
    <h2 class="section-title">Novedades / Blog</h2>

    <div class="blog-filters" id="blog-filters">
      {categories.map((c) => (
        <button class={`filter-btn ${c === 'Todos' ? 'active' : ''}`} data-filter={c}>{c}</button>
      ))}
    </div>

    <div class="blog-grid" id="blog-grid">
      {posts.map((post) => (
        <article class="blog-card" data-category={post.category}>
          <div class="blog-img">
            <img src={post.img} alt={post.title} />
            <span class="blog-cat">{post.category}</span>
          </div>
          <div class="blog-body">
            <time>{post.date}</time>
            <h3>{post.title}</h3>
            <a href="#" class="read-more">Leer más →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.novedades { background: var(--gray-bg); }

.blog-filters {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}
.filter-btn {
  padding: 8px 20px;
  border-radius: 40px;
  border: 1.5px solid rgba(233,30,140,0.25);
  background: var(--white);
  color: var(--gray-text);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}
.filter-btn:hover, .filter-btn.active {
  background: var(--pink);
  color: white;
  border-color: var(--pink);
}

.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.blog-card {
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 2px 16px rgba(0,0,0,0.07);
  transition: transform 0.3s, box-shadow 0.3s, opacity 0.3s;
}
.blog-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 32px rgba(233,30,140,0.14);
}
.blog-card.hidden { display: none; }

.blog-img {
  position: relative;
  height: 180px;
  background: var(--pink-pale);
  overflow: hidden;
}
.blog-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}
.blog-card:hover .blog-img img { transform: scale(1.05); }
.blog-cat {
  position: absolute;
  top: 12px; left: 12px;
  background: var(--pink);
  color: white;
  font-size: 0.75rem;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 40px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.blog-body {
  padding: 20px 20px 24px;
}
.blog-body time {
  font-size: 0.78rem;
  color: var(--pink);
  font-weight: 500;
  display: block;
  margin-bottom: 6px;
}
.blog-body h3 {
  font-size: 1rem;
  font-weight: 600;
  font-family: 'DM Sans', sans-serif;
  line-height: 1.4;
  margin-bottom: 12px;
  color: var(--dark);
}
.read-more {
  font-size: 0.85rem;
  color: var(--pink);
  font-weight: 600;
  transition: letter-spacing 0.2s;
}
.read-more:hover { letter-spacing: 0.03em; }

@media (max-width: 900px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 580px) { .blog-grid { grid-template-columns: 1fr; } }
</style>

<script>
const filterBtns = document.querySelectorAll('.filter-btn');
const cards = document.querySelectorAll('.blog-card');

filterBtns.forEach((btn) => {
  btn.addEventListener('click', () => {
    filterBtns.forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
    const filter = btn.dataset.filter;
    cards.forEach((card) => {
      if (filter === 'Todos' || card.dataset.category === filter) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  });
});
</script>
