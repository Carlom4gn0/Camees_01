<section id="asociate" class="asociate">
  <div class="container">
    <div class="asociate-inner">
      <div class="asociate-text">
        <h2>¿Querés formar parte de nuestra red?</h2>
        <p>
          Sumate a una comunidad de mujeres que se acompañan, se potencian y crecen juntas.
          Como socia, vas a poder acceder a formación, espacios de venta, actividades especiales,
          recursos y un entorno que impulsa tu proyecto.
        </p>
        <div class="asociate-benefits">
          <div class="benefit"><span>✅</span> Capacitaciones y talleres</div>
          <div class="benefit"><span>✅</span> Espacios de venta en ferias</div>
          <div class="benefit"><span>✅</span> Asesoramiento personalizado</div>
          <div class="benefit"><span>✅</span> Red de contactos y colaboraciones</div>
          <div class="benefit"><span>✅</span> Acceso a recursos y microcréditos</div>
          <div class="benefit"><span>✅</span> Visibilidad y promoción</div>
        </div>

        <div class="office-info">
          <h4>🗓 Atención en nuestras oficinas</h4>
          <p>
            <strong>Martes y viernes de 9 a 13 hs</strong><br/>
            Podés acercarte para consultas, inscribirse a talleres o ferias, asesoramiento personalizado,
            informarte sobre actividades o simplemente compartir tus ideas con nosotras.
          </p>
          <a
            href="https://wa.me/5493425000000"
            target="_blank"
            rel="noopener"
            class="btn btn-whatsapp"
          >
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Escribinos por WhatsApp
          </a>
        </div>
      </div>

      <div class="asociate-form">
        <h3>Formulario de Asociación</h3>
        <form id="form-asociate" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="as-nombre">Nombre *</label>
              <input type="text" id="as-nombre" name="nombre" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <label for="as-apellido">Apellido *</label>
              <input type="text" id="as-apellido" name="apellido" placeholder="Tu apellido" required />
            </div>
          </div>
          <div class="form-group">
            <label for="as-email">Email *</label>
            <input type="email" id="as-email" name="email" placeholder="tu@email.com" required />
          </div>
          <div class="form-group">
            <label for="as-tel">Teléfono / WhatsApp</label>
            <input type="tel" id="as-tel" name="telefono" placeholder="+54 9 342 000-0000" />
          </div>
          <div class="form-group">
            <label for="as-rubro">Rubro / Actividad</label>
            <input type="text" id="as-rubro" name="rubro" placeholder="¿A qué te dedicás?" />
          </div>
          <div class="form-group">
            <label for="as-mensaje">¿Por qué querés sumarte? (opcional)</label>
            <textarea id="as-mensaje" name="mensaje" rows="3" placeholder="Contanos tu historia..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-full">Enviar solicitud ✨</button>
          <p class="form-note">Nos pondremos en contacto con vos a la brevedad.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
.asociate {
  background: linear-gradient(135deg, var(--pink-pale) 0%, #fff5f9 100%);
  position: relative;
  overflow: hidden;
}
.asociate::before {
  content: '';
  position: absolute;
  top: -80px; right: -80px;
  width: 300px; height: 300px;
  border-radius: 50%;
  background: rgba(233,30,140,0.06);
}

.asociate-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}

.asociate-text h2 {
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  color: var(--pink-dark);
  margin-bottom: 16px;
}
.asociate-text > p {
  color: var(--gray-text);
  margin-bottom: 28px;
  font-size: 1rem;
}
.asociate-benefits {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 32px;
}
.benefit {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9rem;
  color: var(--dark);
  font-weight: 500;
}

.office-info {
  background: var(--white);
  border-radius: var(--radius);
  padding: 24px;
  border-left: 4px solid var(--pink);
}
.office-info h4 {
  font-family: 'DM Sans', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  margin-bottom: 10px;
  color: var(--dark);
}
.office-info p {
  font-size: 0.9rem;
  color: var(--gray-text);
  margin-bottom: 16px;
  line-height: 1.6;
}

.btn-whatsapp {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #25d366;
  color: white;
  padding: 10px 22px;
  border-radius: 40px;
  font-weight: 600;
  font-size: 0.9rem;
  transition: all 0.2s;
}
.btn-whatsapp:hover {
  background: #1fba59;
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(37,211,102,0.4);
}

/* Form */
.asociate-form {
  background: var(--white);
  border-radius: var(--radius);
  padding: 36px 32px;
  box-shadow: var(--shadow);
}
.asociate-form h3 {
  font-size: 1.4rem;
  color: var(--pink-dark);
  margin-bottom: 24px;
}
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 16px;
}
.form-group label { font-size: 0.85rem; font-weight: 600; color: var(--dark); }
.form-group input,
.form-group textarea,
.form-group select {
  border: 1.5px solid #e4e4e4;
  border-radius: 8px;
  padding: 10px 14px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.93rem;
  color: var(--dark);
  background: var(--white);
  transition: border-color 0.2s, box-shadow 0.2s;
  outline: none;
}
.form-group input:focus,
.form-group textarea:focus {
  border-color: var(--pink);
  box-shadow: 0 0 0 3px rgba(233,30,140,0.10);
}
.form-group textarea { resize: vertical; min-height: 80px; }
.btn-full { width: 100%; text-align: center; padding: 14px; font-size: 1rem; border-radius: 10px; }
.form-note { font-size: 0.8rem; color: var(--gray-text); text-align: center; margin-top: 10px; }

@media (max-width: 900px) {
  .asociate-inner { grid-template-columns: 1fr; }
  .asociate-benefits { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
}
</style>

<script>
document.getElementById('form-asociate')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  btn.textContent = 'Enviando...';
  btn.disabled = true;

  // Construir mailto como fallback (sin backend)
  const data = new FormData(form);
  const nombre = data.get('nombre');
  const apellido = data.get('apellido');
  const email = data.get('email');
  const tel = data.get('telefono');
  const rubro = data.get('rubro');
  const msg = data.get('mensaje');

  const body = `Nombre: ${nombre} ${apellido}\nEmail: ${email}\nTeléfono: ${tel}\nRubro: ${rubro}\nMensaje: ${msg}`;
  const mailtoLink = `mailto:camaramujeresemprendedoras@gmail.com?subject=Solicitud de asociación - ${nombre} ${apellido}&body=${encodeURIComponent(body)}`;

  window.location.href = mailtoLink;
  setTimeout(() => {
    btn.textContent = '✅ ¡Solicitud enviada!';
    btn.style.background = '#25d366';
  }, 800);
});
</script>
