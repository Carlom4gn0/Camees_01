<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-bottom: 56px;
  padding-top: 72px; /* navbar height */
}

.hero-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}
.hero-bg img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(190,24,93,0.72) 0%,
    rgba(233,30,140,0.50) 40%,
    rgba(0,0,0,0.30) 100%
  );
}

.hero-content {
  position: relative;
  z-index: 2;
  max-width: 720px;
  color: var(--white);
  padding-top: 80px;
  width="700px";
}

.hero-tagline {
  font-size: 0.85rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  opacity: 0.85;
  margin-bottom: 16px;
  font-weight: 500;
}

.hero-title {
  font-size: 48px;
  font-weight: 700;
  line-height: 1.15;
  margin-bottom: 32px;
  text-shadow: 0 2px 12px rgba(0,0,0,0.2);
}
.hero-title em {
  font-style: italic;
  color: var(--pink-pale);
}

.hero-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}

.hero-social {
  display: flex;
  gap: 16px;
}
.hero-social a {
  color: var(--white);
  opacity: 0.85;
  transition: opacity 0.2s, transform 0.2s;
}
.hero-social a:hover { opacity: 1; transform: translateY(-3px); }

/* Ticker */
.hero-ticker {
  position: relative;
  z-index: 2;
  background: rgba(233,30,140,0.90);
  backdrop-filter: blur(4px);
  padding: 12px 10px;
  overflow: hidden;
  white-space: nowrap;
}
.ticker-inner {
  display: inline-flex;
  gap: 80px;
  animation: ticker 30s linear infinite;
}
.ticker-inner span {
  color: white;
  font-size: 0.9rem;
  font-weight: 500;
}
@keyframes ticker {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

@media (max-width: 600px) {
  .hero-title { font-size: 2rem; }
  .hero-actions { flex-direction: column; }
  .hero-actions .btn { text-align: center; }
}
</style>
