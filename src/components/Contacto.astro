          </div>
        </div>
        <div class="info-block">
          <h4>📍 Ubicación</h4>
          <p>Santa Fe, Argentina</p>
          <div class="map-embed">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d108073.74!2d-60.7!3d-31.63!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95b5a9b278f46d01%3A0xb9b04b25e82d00!2sSanta%20Fe%2C%20Argentina!5e0!3m2!1ses!2sar!4v1620000000000!5m2!1ses!2sar"
              width="100%"
              height="180"
              style="border:0; border-radius: 10px;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Mapa Santa Fe"
            ></iframe>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.contacto { background: var(--white); }

.contacto-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 60px;
  align-items: start;
}

/* Form (reuse styles from global) */
.contacto-form {
  background: var(--gray-bg);
  border-radius: var(--radius);
  padding: 36px 32px;
}
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 16px;
}
.form-group label { font-size: 0.85rem; font-weight: 600; color: var(--dark); }
.form-group input,
.form-group textarea {
  border: 1.5px solid #e4e4e4;
  border-radius: 8px;
  padding: 10px 14px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.93rem;
  background: var(--white);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.form-group input:focus, .form-group textarea:focus {
  border-color: var(--pink);
  box-shadow: 0 0 0 3px rgba(233,30,140,0.10);
}
.form-group textarea { resize: vertical; }
.btn-full { width: 100%; text-align: center; padding: 13px; border-radius: 10px; }

/* Info */
.info-block {
  margin-bottom: 28px;
  padding-bottom: 28px;
  border-bottom: 1px solid #f0f0f0;
}
.info-block:last-child { border: none; padding: 0; }
.info-block h4 {
  font-family: 'DM Sans', sans-serif;
  font-weight: 700;
  font-size: 0.9rem;
  color: var(--pink);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.info-block a, .info-block p {
  font-size: 0.92rem;
  color: var(--gray-text);
}
.info-block a:hover { color: var(--pink); }

.social-links { display: flex; flex-direction: column; gap: 8px; }
.social-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: 40px;
  font-size: 0.85rem;
  font-weight: 500;
  transition: all 0.2s;
  width: fit-content;
}
.social-pill.ig { background: #fce7f3; color: #be185d; }
.social-pill.fb { background: #eff6ff; color: #1d4ed8; }
.social-pill:hover { transform: translateX(4px); }

@media (max-width: 900px) {
  .contacto-grid { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
}
</style>

<script>
document.getElementById('form-contacto')?.addEventListener('submit', (e) => {
  e.preventDefault();
  const data = new FormData(e.target as HTMLFormElement);
  const nombre = data.get('nombre');
  const apellido = data.get('apellido');
  const email = data.get('email');
  const msg = data.get('mensaje');
  const body = `Nombre: ${nombre} ${apellido}\nEmail: ${email}\n\nMensaje:\n${msg}`;
  window.location.href = `mailto:camaramujeresemprendedoras@gmail.com?subject=Consulta desde la web - ${nombre} ${apellido}&body=${encodeURIComponent(body)}`;
});
</script>
